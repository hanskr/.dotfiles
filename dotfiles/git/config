[include]
	path = ~/.config/git/config_local
[core]
	excludesfile = ~/.config/git/ignore_global
	autocrlf = input
	pager = delta
[diff]
	colorMoved = dimmed-zebra
[pull]
	rebase = true
[branch]
	autosetuprebase = always
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictStyle = zdiff3
[delta]
	navigate = true

[includeIf "hasconfig:remote.*.url:**hanskr**"]
  path = ~/.config/git/config_private

[includeIf "hasconfig:remote.*.url:**m10s-green**"]
  path = ~/.config/git/config_work

[includeIf "hasconfig:remote.*.url:**m10s-red**"]
  path = ~/.config/git/config_work

[includeIf "hasconfig:remote.*.url:**m10s-sandbox**"]
  path = ~/.config/git/config_work
